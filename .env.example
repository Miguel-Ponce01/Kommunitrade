# Google Maps JavaScript API (Needed on the client side for rendering maps)
VITE_GOOGLE_MAPS_API_KEY="YOUR_GOOGLE_MAPS_API_KEY_HERE"

# App Check & ReCAPTCHA Configuration
VITE_RECAPTCHA_SITE_KEY="YOUR_RECAPTCHA_SITE_KEY_HERE"
VITE_DISABLE_APP_CHECK="true"
VITE_APPCHECK_DEBUG_TOKEN="YOUR_APPCHECK_DEBUG_TOKEN_HERE"

# Note: Backend API keys (GEMINI_API_KEY, GOOGLE_VISION_API_KEY, DEEPSEEK_API_KEY)
# are configured in functions/.env for security, and are not exposed to the client.

# Roboflow API configuration
VITE_ROBOFLOW_API_KEY="YOUR_ROBOFLOW_API_KEY_HERE"

# Administrator Access Credentials (dev/local access)
VITE_ADMIN_EMAIL="YOUR_ADMIN_EMAIL_HERE"
VITE_ADMIN_PASSWORD="YOUR_ADMIN_PASSWORD_HERE"
VITE_ADMIN_DISPLAY_NAME="YOUR_ADMIN_DISPLAY_NAME_HERE"
