rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Listings: Anyone can read, only listing owner can modify/delete
    match /listings/{listingId} {
      allow read: if true;
      allow create: if request.auth != null && request.resource.data.sellerId == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.sellerId == request.auth.uid;
    }
    
    // Transactions
    match /transactions/{transactionId} {
      allow read: if request.auth != null && (resource.data.sellerId == request.auth.uid || resource.data.buyerId == request.auth.uid);
      allow create: if request.auth != null;
    }
    
    // Users: Anyone can read profiles, owner can write basic fields but not verification info
    match /users/{userId} {
      allow read: if true;
      allow create: if request.auth != null && request.auth.uid == userId
        && (!(request.resource.data.keys().hasAny(['isVerified', 'verified', 'verificationScore', 'verifiedAt'])) 
            || (request.resource.data.get('isVerified', false) == false && request.resource.data.get('verified', false) == false));
      allow update: if request.auth != null && request.auth.uid == userId
        && !(request.resource.data.diff(resource.data).affectedKeys().hasAny(['isVerified', 'verified', 'verificationScore', 'verifiedAt']));
    }
    
    // Chats: Only participants can read/write to their specific chat threads
    // Note: Chat ID is composed as [uid1, uid2, itemId].sort().join('_')
    match /chats/{chatId} {
      allow read: if request.auth != null && (request.auth.uid in resource.data.participants);
      allow write: if request.auth != null && (chatId.matches(".*" + request.auth.uid + ".*"));
      
      match /messages/{messageId} {
        allow read, write: if request.auth != null && (chatId.matches(".*" + request.auth.uid + ".*"));
      }
    }
  }
}
