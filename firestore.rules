rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAdmin() {
      return request.auth != null && (
        request.auth.token.email == 'admin@komunitrade.com' ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }

    // Listings: Anyone can read, only listing owner or admin can modify/delete
    match /listings/{listingId} {
      allow read: if true;
      allow create: if request.auth != null && request.resource.data.sellerId == request.auth.uid;
      allow update, delete: if request.auth != null && (resource.data.sellerId == request.auth.uid || isAdmin());
    }
    
    // Transactions
    match /transactions/{transactionId} {
      allow read: if request.auth != null && (resource.data.sellerId == request.auth.uid || resource.data.buyerId == request.auth.uid || isAdmin());
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && isAdmin();
    }
    
    // Users: Anyone can read profiles, owner or admin can write
    match /users/{userId} {
      allow read: if true;
      allow create: if request.auth != null && (request.auth.uid == userId || isAdmin())
        && (isAdmin() || !(request.resource.data.keys().hasAny(['isVerified', 'verified', 'verificationScore', 'verifiedAt'])) 
            || (request.resource.data.get('isVerified', false) == false && request.resource.data.get('verified', false) == false));
      allow update: if request.auth != null && (request.auth.uid == userId || isAdmin())
        && (isAdmin() || !(request.resource.data.diff(resource.data).affectedKeys().hasAny(['isVerified', 'verified', 'verificationScore', 'verifiedAt'])));
      allow delete: if request.auth != null && isAdmin();

      // Reviews subcollection
      match /reviews/{reviewId} {
        allow read: if true;
        allow write: if request.auth != null;
      }
    }
    
    // Chats: Only participants or admin can read/write to their specific chat threads
    match /chats/{chatId} {
      allow read: if request.auth != null && (request.auth.uid in resource.data.participants || isAdmin());
      allow write: if request.auth != null && (chatId.matches(".*" + request.auth.uid + ".*") || isAdmin());
      
      match /messages/{messageId} {
        allow read, write: if request.auth != null && (chatId.matches(".*" + request.auth.uid + ".*") || isAdmin());
      }
    }

    // Feedback: Anyone can read/create, only admin can delete
    match /feedback/{feedbackId} {
      allow read, create: if true;
      allow update, delete: if isAdmin();
    }
  }
}
