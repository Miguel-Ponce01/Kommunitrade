rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAdmin() {
      return request.auth != null && (
        request.auth.token.email == 'admin@komunitrade.com' ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }

    function isAppChecked() {
      // Enforce App Check in production, but allow admin overrides or emulator bypass
      return request.app != null || request.auth.token.email == 'admin@komunitrade.com';
    }

    // Listings: Anyone can read, only listing owner or admin can modify/delete
    match /listings/{listingId} {
      allow read: if true;
      allow create: if request.auth != null && request.resource.data.sellerId == request.auth.uid && isAppChecked();
      allow update: if request.auth != null && (resource.data.sellerId == request.auth.uid || isAdmin())
        && request.resource.data.sellerId == resource.data.sellerId;
      allow delete: if request.auth != null && (resource.data.sellerId == request.auth.uid || isAdmin());
    }
    
    // Transactions
    match /transactions/{transactionId} {
      allow read: if request.auth != null && (resource.data.sellerId == request.auth.uid || resource.data.buyerId == request.auth.uid || isAdmin());
      allow create: if request.auth != null && isAppChecked();
      allow update: if request.auth != null && (resource.data.sellerId == request.auth.uid || resource.data.buyerId == request.auth.uid || isAdmin());
      allow delete: if request.auth != null && isAdmin();
    }
    
    // Users: Anyone can read profiles, owner or admin can write
    match /users/{userId} {
      allow read: if true;
      allow create: if request.auth != null && (request.auth.uid == userId || isAdmin())
        && isAppChecked()
        && (isAdmin() || (
            // Regular users cannot verify themselves on creation
            !(request.resource.data.keys().hasAny(['isVerified', 'verified', 'verificationScore', 'verifiedAt'])) 
            || (request.resource.data.get('isVerified', false) == false && request.resource.data.get('verified', false) == false)
           ) && (
            // Regular users cannot grant themselves admin role on creation
            !request.resource.data.keys().hasAny(['role']) || request.resource.data.get('role', 'user') == 'user'
           ));
      allow update: if request.auth != null && (request.auth.uid == userId || isAdmin())
        && (isAdmin() || (
            // Prevent regular users from self-promoting to admin or self-verifying
            !(request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'isVerified', 'verified', 'verificationScore', 'verifiedAt']))
           ));
      allow delete: if request.auth != null && isAdmin();

      // Reviews subcollection
      match /reviews/{reviewId} {
        allow read: if true;
        allow write: if request.auth != null && isAppChecked();
      }
    }
    
    // Chats: Only participants or admin can read/write to their specific chat threads
    match /chats/{chatId} {
      allow read: if request.auth != null && (request.auth.uid in resource.data.participants || isAdmin());
      allow write: if request.auth != null && (chatId.matches(".*" + request.auth.uid + ".*") || isAdmin()) && isAppChecked();
      
      match /messages/{messageId} {
        allow read: if request.auth != null && (chatId.matches(".*" + request.auth.uid + ".*") || isAdmin());
        allow create: if request.auth != null && (chatId.matches(".*" + request.auth.uid + ".*") || isAdmin())
          && (request.resource.data.senderId == request.auth.uid || isAdmin())
          && isAppChecked();
        allow update, delete: if request.auth != null && (resource.data.senderId == request.auth.uid || isAdmin());
      }
    }

    // Feedback: Anyone can read/create, only admin can delete
    match /feedback/{feedbackId} {
      allow read, create: if true;
      allow update, delete: if isAdmin();
    }

    // Offline sync queue
    match /offlineQueue/{queueId} {
      allow create, update: if request.auth != null;
      allow read: if request.auth != null && request.auth.uid == resource.data.userId;
    }

    // Disputes Collection Rules
    match /disputes/{disputeId} {
      allow read: if request.auth != null && (resource.data.reporterId == request.auth.uid || resource.data.reportedUserId == request.auth.uid || isAdmin());
      allow create: if request.auth != null && request.resource.data.reporterId == request.auth.uid && isAppChecked();
      allow update: if request.auth != null && isAdmin();
      allow delete: if request.auth != null && isAdmin();
    }

    // Trust Logs Audit Trail Rules
    match /trust_logs/{logId} {
      allow read: if request.auth != null && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if request.auth != null && (request.resource.data.userId == request.auth.uid || isAdmin()) && isAppChecked();
      allow update, delete: if request.auth != null && isAdmin();
    }
  }
}
